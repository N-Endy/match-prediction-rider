@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    var adClientId = Configuration["AdSense:ClientId"] ?? "ca-pub-123456789";
}

<div class="mp-ad-wrapper">
    <!-- Placeholder for AdSense or actual AdSense Tag -->
    <ins class="adsbygoogle mp-ad-ins"
         style="display:block; text-align:center;"
         data-ad-layout="in-article"
         data-ad-format="fluid"
         data-ad-client="@adClientId"
         data-ad-slot="6144424563"></ins>
    <script>
        (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
    <div class="mp-ad-fallback">
        <span>Advertisement</span>
    </div>
</div>