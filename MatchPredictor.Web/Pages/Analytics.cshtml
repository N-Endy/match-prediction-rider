@page
@model MatchPredictor.Web.Pages.AnalyticsModel

@{
    ViewData["Title"] = "Analytics Dashboard";
    var defaultTab = Model.DefaultTabId;
}

<div class="mp-container">
    <div class="mp-page-header">
        <div class="mp-page-title">
            <div class="mp-page-title-icon" style="background: rgba(139, 92, 246, 0.1);">📈</div>
            <h1>Performance Analytics</h1>
        </div>
    </div>

    <div class="mp-analytics-tabs">
        <button class="mp-tab-btn @(defaultTab == "today" ? "active" : "")" onclick="switchTab(event, 'today')">Today</button>
        <button class="mp-tab-btn @(defaultTab == "yesterday" ? "active" : "")" onclick="switchTab(event, 'yesterday')">Yesterday</button>
        <button class="mp-tab-btn @(defaultTab == "3days" ? "active" : "")" onclick="switchTab(event, '3days')">Last 3 Days</button>
        <button class="mp-tab-btn @(defaultTab == "7days" ? "active" : "")" onclick="switchTab(event, '7days')">Last 7 Days</button>
    </div>

    <div id="today-stats" class="mp-analytics-section @(defaultTab == "today" ? "active" : "")" style="@(defaultTab == "today" ? "" : "display: none;")">
        @await Html.PartialAsync("_StatCards", Model.TodayStats)
    </div>
    <div id="yesterday-stats" class="mp-analytics-section @(defaultTab == "yesterday" ? "active" : "")" style="@(defaultTab == "yesterday" ? "" : "display: none;")">
        @await Html.PartialAsync("_StatCards", Model.YesterdayStats)
    </div>
    <div id="3days-stats" class="mp-analytics-section @(defaultTab == "3days" ? "active" : "")" style="@(defaultTab == "3days" ? "" : "display: none;")">
        @await Html.PartialAsync("_StatCards", Model.Last3DaysStats)
    </div>
    <div id="7days-stats" class="mp-analytics-section @(defaultTab == "7days" ? "active" : "")" style="@(defaultTab == "7days" ? "" : "display: none;")">
        @await Html.PartialAsync("_StatCards", Model.Last7DaysStats)
    </div>
</div>

@section Scripts {
<script>
    function switchTab(event, tabId) {
        // Hide all sections
        document.querySelectorAll('.mp-analytics-section').forEach(el => {
            el.style.display = 'none';
        });
        
        // Remove active class from all buttons
        document.querySelectorAll('.mp-tab-btn').forEach(el => {
            el.classList.remove('active');
        });
        
        // Show target section and set button active
        document.getElementById(tabId + '-stats').style.display = 'block';
        event.target.classList.add('active');
    }
</script>

<style>
    .mp-analytics-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1rem;
    }

    .mp-tab-btn {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        padding: 0.5rem 1rem;
        border-radius: var(--radius-md);
        cursor: pointer;
        font-weight: 500;
        transition: all 0.2s ease;
    }
    .mp-tab-btn:hover {
        background: rgba(255, 255, 255, 0.05);
        color: white;
    }
    .mp-tab-btn.active {
        background: var(--bg-card);
        color: white;
        border-color: rgba(139, 92, 246, 0.5);
        box-shadow: 0 0 10px rgba(139, 92, 246, 0.1);
    }
    
    .mp-stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    
    .mp-stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.5rem;
        transition: transform 0.2s;
    }
    .mp-stat-card:hover {
        transform: translateY(-2px);
    }
    
    .mp-stat-value {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        font-family: monospace;
        line-height: 1;
    }

    .mp-stat-figure {
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
        min-height: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .mp-stat-value-compact {
        font-size: 2rem;
        min-height: 2rem;
    }
    
    .mp-stat-label {
        color: var(--text-muted);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .mp-category-stats {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
    }
    
    .mp-category-row {
        margin-bottom: 1.5rem;
    }
    .mp-category-row:last-child {
        margin-bottom: 0;
    }
    
    .mp-cat-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    .mp-cat-name {
        font-weight: 600;
        color: white;
    }
    .mp-cat-details {
        color: var(--text-muted);
        display: inline-flex;
        align-items: baseline;
        justify-content: flex-end;
        gap: 0.5rem;
        text-align: right;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    .mp-cat-metric {
        display: inline-flex;
        align-items: baseline;
    }
    
    .mp-progress-track {
        height: 8px;
        background: rgba(255,255,255,0.05);
        border-radius: 4px;
        overflow: hidden;
    }
    .mp-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #10b981, #3b82f6);
        border-radius: 4px;
        transition: width 1s ease-in-out;
    }

    .mp-market-analytics {
        margin-top: 2rem;
    }

    .mp-switch-log {
        margin-top: 2rem;
    }

    .mp-switch-list {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .mp-switch-item {
        display: grid;
        grid-template-columns: 96px minmax(0, 1fr);
        gap: 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1rem 1.1rem;
    }

    .mp-switch-time {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        color: var(--text-muted);
        font-size: 0.78rem;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    .mp-switch-time strong {
        color: white;
        font-size: 0.9rem;
    }

    .mp-switch-body {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .mp-switch-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
    }

    .mp-switch-market {
        color: white;
        font-weight: 600;
    }

    .mp-switch-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        background: rgba(16, 185, 129, 0.12);
        color: #10b981;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .mp-switch-summary {
        color: white;
        font-size: 0.92rem;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    .mp-switch-detail {
        color: var(--text-muted);
        font-size: 0.8rem;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    .mp-market-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
        gap: 1rem;
    }

    .mp-market-empty {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        color: var(--text-muted);
    }

    .mp-market-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .mp-market-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
    }

    .mp-market-header h4 {
        margin: 0;
        color: white;
        font-size: 1rem;
    }

    .mp-market-header p {
        margin: 0.25rem 0 0;
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .mp-market-briers {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.25rem;
        color: var(--text-muted);
        font-size: 0.8rem;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    .mp-market-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
    }

    .mp-market-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem 0.6rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: var(--text-muted);
        font-size: 0.78rem;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    .mp-market-pill strong {
        color: white;
        font-weight: 600;
    }

    .mp-market-pill em {
        font-style: normal;
        color: #10b981;
    }

    .mp-market-meta-note {
        color: var(--text-muted);
        font-size: 0.75rem;
    }

    .mp-market-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .mp-market-metric-block {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: var(--radius-md);
        padding: 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    .mp-market-metric-label {
        color: var(--text-muted);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .mp-reliability-shell {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .mp-market-beta {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: var(--radius-md);
        padding: 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .mp-market-beta-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        color: white;
        font-size: 0.85rem;
    }

    .mp-market-beta-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.45rem 0.9rem;
        color: var(--text-muted);
        font-size: 0.8rem;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    .mp-market-beta-empty {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.78rem;
    }

    .mp-era-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 0.75rem;
        align-items: start;
    }

    .mp-era-card {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: var(--radius-md);
        padding: 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .mp-era-row {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) repeat(3, minmax(0, 0.8fr));
        gap: 0.45rem;
        align-items: center;
        color: var(--text-muted);
        font-size: 0.76rem;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum" 1;
    }

    .mp-era-name {
        color: white;
        font-weight: 600;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .mp-era-row-head {
        padding-bottom: 0.3rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        color: var(--text-muted);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .mp-era-row-head .mp-era-name {
        color: var(--text-muted);
        font-weight: 500;
    }

    .mp-era-metric {
        text-align: right;
        min-width: 0;
        white-space: nowrap;
    }

    .mp-reliability-chart {
        position: relative;
        height: 180px;
        border-radius: var(--radius-md);
        border: 1px solid rgba(255, 255, 255, 0.08);
        background:
            linear-gradient(to top, rgba(255,255,255,0.04) 1px, transparent 1px) 0 0 / 100% 25%,
            linear-gradient(to right, rgba(255,255,255,0.04) 1px, transparent 1px) 0 0 / 25% 100%,
            linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
        overflow: hidden;
    }

    .mp-reliability-chart svg {
        width: 100%;
        height: 100%;
    }

    .mp-reliability-diagonal {
        stroke: rgba(255, 255, 255, 0.25);
        stroke-width: 1;
        stroke-dasharray: 3 3;
    }

    .mp-reliability-line {
        fill: none;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .mp-reliability-line.raw,
    .mp-curve-point.raw,
    .mp-legend-swatch.raw {
        stroke: #f59e0b;
        background: #f59e0b;
        fill: #f59e0b;
    }

    .mp-reliability-line.calibrated,
    .mp-curve-point.calibrated,
    .mp-legend-swatch.calibrated {
        stroke: #10b981;
        background: #10b981;
        fill: #10b981;
    }

    .mp-reliability-legend {
        display: flex;
        gap: 1rem;
        color: var(--text-muted);
        font-size: 0.8rem;
    }

    .mp-legend-swatch {
        display: inline-block;
        width: 0.75rem;
        height: 0.75rem;
        border-radius: 999px;
        margin-right: 0.35rem;
        vertical-align: middle;
    }
    
    .acc-high { color: #10b981; }
    .acc-med { color: #f59e0b; }
    .acc-low { color: #ef4444; }

    @@media (max-width: 640px) {
        .mp-cat-header {
            grid-template-columns: 1fr;
            gap: 0.35rem;
        }

        .mp-cat-details {
            justify-content: flex-start;
            text-align: left;
            flex-wrap: wrap;
            white-space: normal;
        }

        .mp-market-header {
            flex-direction: column;
        }

        .mp-market-briers {
            align-items: flex-start;
        }

        .mp-switch-item {
            grid-template-columns: 1fr;
        }

        .mp-switch-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .mp-market-meta {
            align-items: stretch;
        }

        .mp-market-metrics {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .mp-market-beta-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .mp-market-beta-grid {
            grid-template-columns: 1fr;
        }

        .mp-era-grid {
            grid-template-columns: 1fr;
        }

        .mp-era-row {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
</style>
}
