@page
@model MatchPredictor.Web.Pages.AnalyticsModel

@{
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="mp-container">
    <div class="mp-page-header">
        <div class="mp-page-title">
            <div class="mp-page-title-icon" style="background: rgba(139, 92, 246, 0.1);">📈</div>
            <h1>Performance Analytics</h1>
        </div>
    </div>

    <div class="mp-analytics-tabs">
        <button class="mp-tab-btn active" onclick="switchTab('today')">Today</button>
        <button class="mp-tab-btn" onclick="switchTab('yesterday')">Yesterday</button>
        <button class="mp-tab-btn" onclick="switchTab('3days')">Last 3 Days</button>
        <button class="mp-tab-btn" onclick="switchTab('7days')">Last 7 Days</button>
    </div>

    <div id="today-stats" class="mp-analytics-section active">
        @await Html.PartialAsync("_StatCards", Model.TodayStats)
    </div>
    <div id="yesterday-stats" class="mp-analytics-section" style="display: none;">
        @await Html.PartialAsync("_StatCards", Model.YesterdayStats)
    </div>
    <div id="3days-stats" class="mp-analytics-section" style="display: none;">
        @await Html.PartialAsync("_StatCards", Model.Last3DaysStats)
    </div>
    <div id="7days-stats" class="mp-analytics-section" style="display: none;">
        @await Html.PartialAsync("_StatCards", Model.Last7DaysStats)
    </div>
</div>

@section Scripts {
<script>
    function switchTab(tabId) {
        // Hide all sections
        document.querySelectorAll('.mp-analytics-section').forEach(el => {
            el.style.display = 'none';
        });
        
        // Remove active class from all buttons
        document.querySelectorAll('.mp-tab-btn').forEach(el => {
            el.classList.remove('active');
        });
        
        // Show target section and set button active
        document.getElementById(tabId + '-stats').style.display = 'block';
        event.target.classList.add('active');
    }
</script>

<style>
    .mp-analytics-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1rem;
    }
    .mp-tab-btn {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        padding: 0.5rem 1rem;
        border-radius: var(--radius-md);
        cursor: pointer;
        font-weight: 500;
        transition: all 0.2s ease;
    }
    .mp-tab-btn:hover {
        background: rgba(255, 255, 255, 0.05);
        color: white;
    }
    .mp-tab-btn.active {
        background: var(--bg-card);
        color: white;
        border-color: rgba(139, 92, 246, 0.5);
        box-shadow: 0 0 10px rgba(139, 92, 246, 0.1);
    }
    
    .mp-stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    
    .mp-stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        text-align: center;
        transition: transform 0.2s;
    }
    .mp-stat-card:hover {
        transform: translateY(-2px);
    }
    
    .mp-stat-value {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0.5rem 0;
        font-family: monospace;
    }
    
    .mp-stat-label {
        color: var(--text-muted);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .mp-category-stats {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
    }
    
    .mp-category-row {
        margin-bottom: 1.5rem;
    }
    .mp-category-row:last-child {
        margin-bottom: 0;
    }
    
    .mp-cat-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    .mp-cat-name {
        font-weight: 600;
        color: white;
    }
    .mp-cat-details {
        color: var(--text-muted);
    }
    
    .mp-progress-track {
        height: 8px;
        background: rgba(255,255,255,0.05);
        border-radius: 4px;
        overflow: hidden;
    }
    .mp-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #10b981, #3b82f6);
        border-radius: 4px;
        transition: width 1s ease-in-out;
    }
    
    .acc-high { color: #10b981; }
    .acc-med { color: #f59e0b; }
    .acc-low { color: #ef4444; }
</style>
}
