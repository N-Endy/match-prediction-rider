@page
@model MatchPredictor.Web.Pages.Predictions.Over2

@{
    ViewData["Title"] = "Over 2.5 Goals";
    var today = DateTime.UtcNow.ToString("dd MMM yyyy");
    var count = Model.Matches?.Count ?? 0;
}

<div class="mp-container">
    <div class="mp-page-header">
        <div class="mp-page-title">
            <div class="mp-page-title-icon" style="background: rgba(59, 130, 246, 0.1);">🎯</div>
            <h1>Over 2.5 Goals</h1>
        </div>
        <div class="mp-date-badge">📅 @today</div>
    </div>

    @if (count > 0)
    {
        <div class="mp-match-count">
            <span class="mp-live-dot"></span>
            @count match@(count != 1 ? "es" : "") found
        </div>

        <div class="mp-predictions-list">
            @foreach (var match in Model.Matches!)
            {
                <div class="mp-prediction-card">
                    <div class="mp-match-info">
                        <div class="mp-match-league">
                            @match.League
                            <span class="mp-time">@(DateTime.TryParse(match.Time, out var t) ? t.AddHours(-1).ToString("h:mm tt") : match.Time)</span>
                        </div>
                        <div class="mp-match-teams">
                            @match.HomeTeam
                            <span class="mp-vs">vs</span>
                            @match.AwayTeam
                        </div>
                    </div>
                    <div class="mp-card-badges">
                        @if (!string.IsNullOrEmpty(match.ActualScore))
                        {
                            var isCorrect = match.PredictedOutcome == match.ActualOutcome;
                            if (match.IsLive)
                            {
                                if (isCorrect) 
                                {
                                    <span class="mp-score mp-score-correct"><span class="mp-live-indicator"></span>@match.ActualScore</span>
                                }
                                else
                                {
                                    <span class="mp-score mp-score-live"><span class="mp-live-indicator"></span>@match.ActualScore</span>
                                }
                            }
                            else
                            {
                                <span class="mp-score @(isCorrect ? "mp-score-correct" : "mp-score-incorrect")">
                                    @match.ActualScore
                                </span>
                            }
                        }
                        <span class="mp-prediction-badge mp-badge-over">Over 2.5</span>
                        <button class="mp-add-cart-btn" title="Add Bet"
                                data-home="@match.HomeTeam"
                                data-away="@match.AwayTeam"
                                data-league="@match.League"
                                data-market="Over2.5"
                                data-prediction="Over 2.5">
                            Add Bet
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="mp-empty-state">
            <div class="mp-empty-state-icon">🎯</div>
            <p>No Over 2.5 goals predictions available for today yet.</p>
            <p style="font-size: 0.85rem; margin-top: 0.5rem;">Predictions are updated daily. Check back soon!</p>
        </div>
    }
</div>