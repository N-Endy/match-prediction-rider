@page
@model MatchPredictor.Web.Pages.AiChatModel

@{
    ViewData["Title"] = "AI Chat";
}

<div class="mp-container">
    <div class="mp-page-header">
        <div class="mp-page-title">
            <div class="mp-page-title-icon" style="background: rgba(99, 102, 241, 0.1);">🤖</div>
            <h1>AI Prediction Advisor</h1>
        </div>
    </div>

@if (!Model.IsAuthenticated)
{
    <div class="mp-ai-auth-container" style="max-width: 400px; margin: 4rem auto; text-align: center; padding: 2rem; background: var(--bg-card); border-radius: var(--radius-lg); border: 1px solid var(--border-color);">
        <div style="font-size: 3rem; margin-bottom: 1rem;">🔒</div>
        <h2 style="margin-bottom: 0.5rem;">Access Restricted</h2>
        <p style="color: var(--text-muted); margin-bottom: 1.5rem; font-size: 0.9rem;">
            Please enter the password to access the AI Prediction Advisor.
        </p>
        
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div style="color: var(--accent-rose); background: rgba(244, 63, 94, 0.1); padding: 0.75rem; border-radius: var(--radius-sm); margin-bottom: 1rem; font-size: 0.85rem;">
                @Model.ErrorMessage
            </div>
        }

        <form method="post" style="display: flex; flex-direction: column; gap: 1rem;">
            <input type="password" asp-for="Password" 
                   class="mp-chat-input" 
                   style="text-align: center; border-radius: var(--radius-md);" 
                   placeholder="Enter Password" 
                   required autofocus />
            <button type="submit" class="mp-book-btn" style="width: 100%; border-radius: var(--radius-md); padding: 0.75rem;">
                Unlock Chat
            </button>
        </form>
    </div>
}
else
{
    <div class="mp-chat-container" id="chatContainer">
        <div class="mp-chat-messages" id="chatMessages">
            <div class="mp-chat-message mp-chat-ai">
                <div class="mp-chat-avatar">🤖</div>
                <div class="mp-chat-bubble">
                    <p>Hello! I'm Nelson, your grounded prediction advisor. I only work from today's MatchPredictor card, so every pick I discuss comes from the predictions currently in the system.</p>
                    <p style="margin-top: 0.5rem; font-size: 0.85rem; opacity: 0.7;">Try asking:</p>
                    <ul style="font-size: 0.85rem; opacity: 0.7; margin: 0.25rem 0 0 1rem;">
                        <li>"Give me 10 of the best BTTS predictions"</li>
                        <li>"Pick 5 safe straight wins"</li>
                        <li>"Give me 3 strong picks and add them to the slip"</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="mp-chat-input-area">
            <input type="text" id="chatInput" class="mp-chat-input"
                   placeholder="Ask about today's predictions..."
                   autocomplete="off" />
            <button id="chatSendBtn" class="mp-chat-send-btn" onclick="sendChatMessage()">
                Send
            </button>
        </div>
    </div>
}
</div>

@section Scripts {
<script>
    const chatMessages = document.getElementById('chatMessages');
    const chatInput = document.getElementById('chatInput');
    const chatSendBtn = document.getElementById('chatSendBtn');
    if (chatInput && chatSendBtn) {
        chatInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendChatMessage();
            }
        });
    }

    function appendTextMessage(role, text) {
        const div = document.createElement('div');
        div.className = `mp-chat-message mp-chat-${role}`;

        const avatar = document.createElement('div');
        avatar.className = 'mp-chat-avatar';
        avatar.textContent = role === 'ai' ? '🤖' : '👤';

        const bubble = document.createElement('div');
        bubble.className = 'mp-chat-bubble';
        bubble.innerHTML = formatMessageHtml(text);

        div.appendChild(avatar);
        div.appendChild(bubble);
        chatMessages.appendChild(div);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function appendAiResponse(response) {
        const div = document.createElement('div');
        div.className = 'mp-chat-message mp-chat-ai';

        const avatar = document.createElement('div');
        avatar.className = 'mp-chat-avatar';
        avatar.textContent = '🤖';

        const bubble = document.createElement('div');
        bubble.className = 'mp-chat-bubble';

        const message = document.createElement('div');
        message.innerHTML = formatMessageHtml(response.message || '');
        bubble.appendChild(message);

        if (Array.isArray(response.warnings) && response.warnings.length > 0) {
            const warnings = document.createElement('div');
            warnings.style.marginTop = '0.75rem';
            warnings.style.fontSize = '0.8rem';
            warnings.style.opacity = '0.75';
            warnings.innerHTML = response.warnings
                .map(warning => `<div>${escapeHtml(warning)}</div>`)
                .join('');
            bubble.appendChild(warnings);
        }

        if (Array.isArray(response.actions) && response.actions.length > 0) {
            const actions = document.createElement('div');
            actions.style.display = 'grid';
            actions.style.gap = '0.75rem';
            actions.style.marginTop = '0.85rem';

            response.actions.forEach(action => {
                const card = document.createElement('div');
                card.style.padding = '0.85rem';
                card.style.borderRadius = '12px';
                card.style.border = '1px solid rgba(148, 163, 184, 0.16)';
                card.style.background = 'rgba(15, 23, 42, 0.35)';

                const title = document.createElement('div');
                title.style.fontWeight = '600';
                title.style.fontSize = '0.9rem';
                title.textContent = `${action.homeTeam} vs ${action.awayTeam}`;
                card.appendChild(title);

                const meta = document.createElement('div');
                meta.style.marginTop = '0.3rem';
                meta.style.fontSize = '0.75rem';
                meta.style.opacity = '0.72';
                meta.textContent = `${action.league || 'Today'} • ${action.market || 'Market'} • ${action.prediction || 'Pick'}`;
                card.appendChild(meta);

                if (action.explanation) {
                    const explanation = document.createElement('div');
                    explanation.style.marginTop = '0.55rem';
                    explanation.style.fontSize = '0.82rem';
                    explanation.style.lineHeight = '1.5';
                    explanation.innerHTML = formatMessageHtml(action.explanation);
                    card.appendChild(explanation);
                }

                const btn = document.createElement('button');
                btn.className = 'mp-add-cart-btn mp-btn-sm';
                btn.style.display = 'inline-flex';
                btn.style.alignItems = 'center';
                btn.style.justifyContent = 'center';
                btn.style.marginTop = '0.7rem';
                btn.style.padding = '6px 12px';
                btn.style.fontSize = '0.78rem';
                btn.style.borderRadius = '8px';
                btn.style.lineHeight = '1';
                btn.textContent = `+ Add ${action.market}`;
                btn.dataset.home = action.homeTeam || '';
                btn.dataset.away = action.awayTeam || '';
                btn.dataset.league = action.league || '';
                btn.dataset.market = action.market || '';
                btn.dataset.prediction = action.prediction || '';
                card.appendChild(btn);
                actions.appendChild(card);
            });

            bubble.appendChild(actions);

            if (response.showBookAll && response.actions.length > 1) {
                const footer = document.createElement('div');
                footer.style.marginTop = '12px';
                footer.style.paddingTop = '12px';
                footer.style.borderTop = '1px solid rgba(255,255,255,0.1)';

                const btn = document.createElement('button');
                btn.className = 'mp-book-btn';
                btn.style.fontSize = '0.85rem';
                btn.style.padding = '8px 16px';
                btn.style.width = 'auto';
                btn.style.borderRadius = '8px';
                btn.textContent = '🎫 Add All & Open Slip';
                btn.addEventListener('click', () => addAllAndBook(btn));

                footer.appendChild(btn);
                bubble.appendChild(footer);
            }
        }

        div.appendChild(avatar);
        div.appendChild(bubble);
        chatMessages.appendChild(div);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function escapeHtml(text) {
        return String(text ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function formatMessageHtml(text) {
        const escaped = escapeHtml(text);
        return escaped
            .replace(/\n/g, '<br>')
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.*?)\*/g, '<em>$1</em>')
            .replace(/`(.*?)`/g, '<code>$1</code>');
    }

    // Agentic UI Action
    function addAllAndBook(btn) {
        const bubble = btn.closest('.mp-chat-bubble');
        if (!bubble) return;
        
        const betBtns = bubble.querySelectorAll('.mp-add-cart-btn');
        if (betBtns.length === 0) return;
        
        let addedCount = 0;
        betBtns.forEach(b => {
            if (typeof addToCart === 'function') {
                addToCart({
                    homeTeam: b.dataset.home || '',
                    awayTeam: b.dataset.away || '',
                    league: b.dataset.league || '',
                    market: b.dataset.market || '',
                    prediction: b.dataset.prediction || ''
                });
                addedCount++;
            }
        });
        
        if (typeof openCartModal === 'function') {
            openCartModal();
        }
        
        btn.textContent = `Added ${addedCount} picks!`;
        btn.disabled = true;
        btn.style.opacity = '0.7';
    }

    function showTypingIndicator() {
        const div = document.createElement('div');
        div.className = 'mp-chat-message mp-chat-ai mp-chat-typing';
        div.id = 'typingIndicator';
        div.innerHTML = `
            <div class="mp-chat-avatar">🤖</div>
            <div class="mp-chat-bubble">
                <div class="mp-typing-dots">
                    <span></span><span></span><span></span>
                </div>
            </div>
        `;
        chatMessages.appendChild(div);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function removeTypingIndicator() {
        const indicator = document.getElementById('typingIndicator');
        if (indicator) indicator.remove();
    }

    async function sendChatMessage() {
        const message = chatInput.value.trim();
        if (!message) return;

        // Show user message
        appendTextMessage('user', message);
        chatInput.value = '';
        chatSendBtn.disabled = true;

        showTypingIndicator();

        try {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 30000);

            const response = await fetch('/api/ai/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message }),
                signal: controller.signal
            });

            clearTimeout(timeoutId);
            removeTypingIndicator();

            if (response.ok) {
                const data = await response.json();
                appendAiResponse(data);
            } else {
                const errorData = await response.json().catch(() => null);
                const errorMsg = errorData?.message || 'Something went wrong. Please try again.';
                appendAiResponse({ message: `❌ ${errorMsg}`, actions: [], showBookAll: false, warnings: [] });
            }
        } catch (err) {
            removeTypingIndicator();
            if (err.name === 'AbortError') {
                appendAiResponse({ message: '⏳ Request timed out. The AI service may be busy — please try again in a moment.', actions: [], showBookAll: false, warnings: [] });
            } else {
                appendAiResponse({ message: '❌ Network error. Please check your connection and try again.', actions: [], showBookAll: false, warnings: [] });
            }
        } finally {
            chatSendBtn.disabled = false;
            chatInput.focus();
        }
    }
</script>
}
