@page "/valuebets"
@model MatchPredictor.Web.Pages.ValueBetsModel
@{
    ViewData["Title"] = "AI Value Bets";
}

<div class="mp-container">
    <div class="mp-header-area">
        <h1 class="mp-page-title">🎯 AI Value Bets</h1>
        <h3 class="mp-page-subtitle">Highly profitable mathematical mismatches hand-picked by our AI Handicapper.</p>
    </div>

    <!-- AI Loading State -->
    <div id="aiLoadingState" style="text-align: center; padding: 4rem 1rem;">
        <div style="display: flex; justify-content: center; margin-bottom: 1.5rem;">
            <div class="mp-spinner"></div>
        </div>
        <h3>🧠 AI is analyzing the top value plays...</h3>
        <p style="color: var(--text-muted); font-size: 0.95rem;">Scanning mathematical probabilities vs bookmaker odds.</p>
    </div>

    <!-- No Bets State -->
    <div id="noBetsState" style="display: none; text-align: center; padding: 4rem 1rem; background: var(--card-bg); border-radius: 12px; border: 1px solid var(--border-color);">
        <h3 style="margin-bottom: 0.5rem;">No Value Bets Right Now</h3>
        <p style="color: var(--text-muted);">We only show bets with a mathematical probability greater than 75%. Check back later as odds shift.</p>
    </div>

    <!-- Error State -->
    <div id="errorState" style="display: none; text-align: center; padding: 4rem 1rem; background: #fff3f3; color: #dc3545; border-radius: 12px; border: 1px solid #ffdcdc;">
        <h3 id="errorMessage" style="margin-bottom: 0.5rem; color: #dc3545;">Failed to load AI Value Bets</h3>
        <p>There was an error communicating with the AI service. Please refresh the page to try again.</p>
    </div>

    <!-- Results Grid -->
    <div id="valueBetsGrid" style="display: none;" class="mp-grid">
        <!-- Rendered via JS -->
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const loadingState = document.getElementById('aiLoadingState');
            const noBetsState = document.getElementById('noBetsState');
            const errorState = document.getElementById('errorState');
            const errorMessage = document.getElementById('errorMessage');
            const grid = document.getElementById('valueBetsGrid');

            try {
                const response = await fetch('/api/valuebets');
                
                if (!response.ok) {
                    throw new Error('Failed to load Value Bets data from the server.');
                }

                const valueBets = await response.json();
                
                loadingState.style.display = 'none';

                if (!valueBets || valueBets.length === 0) {
                    noBetsState.style.display = 'block';
                    return;
                }

                grid.style.display = 'grid';
                grid.style.gap = '1.5rem';
                grid.innerHTML = valueBets.map(bet => {
                    const mathProbString = (bet.mathematicalProbability * 100).toFixed(1) + '%';
                    
                    let badgeClass = 'mp-badge-combined'; 
                    if (bet.predictionCategory === 'BTTS') badgeClass = 'mp-badge-btts';
                    else if (bet.predictionCategory === 'Over 2.5') badgeClass = 'mp-badge-over';
                    else if (bet.predictionCategory === 'Draw') badgeClass = 'mp-badge-draw';
                    else if (bet.predictionCategory === 'Home Win' || bet.predictionCategory === 'StraightWin') badgeClass = 'mp-badge-win-home';
                    else if (bet.predictionCategory === 'Away Win') badgeClass = 'mp-badge-win-away';

                    return `
                        <div class="mp-prediction-card" style="flex-direction: column; align-items: stretch; gap: 1rem; position: relative; overflow: hidden; border-top: 4px solid var(--accent-blue);">
                            
                            <!-- Top Row: Standard Match Info -->
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%; gap: 1rem;">
                                <div class="mp-match-info">
                                    <div class="mp-match-league">
                                        ${bet.league}
                                        <span class="mp-time">${bet.kickoffTime}</span>
                                    </div>
                                    <div class="mp-match-teams" style="font-size: 1.15rem; margin-top: 4px;">
                                        ${bet.homeTeam}
                                        <span class="mp-vs">vs</span>
                                        ${bet.awayTeam}
                                    </div>
                                </div>
                                
                                <div class="mp-card-badges" style="display: flex; flex-direction: column; align-items: flex-end; gap: 10px;">
                                    <span class="mp-prediction-badge ${badgeClass}">${bet.predictionCategory}</span>
                                    <button class="mp-add-cart-btn" title="Add Bet"
                                            data-home="${bet.homeTeam}"
                                            data-away="${bet.awayTeam}"
                                            data-league="${bet.league}"
                                            data-market="${bet.predictionCategory}"
                                            data-prediction="${bet.predictedOutcome}">
                                        Add Bet
                                    </button>
                                </div>
                            </div>

                            <!-- Bottom Row: AI Insights -->
                            <div style="background: rgba(59, 130, 246, 0.05); border: 1px solid rgba(59, 130, 246, 0.15); border-radius: 8px; padding: 1.25rem; margin-top: 0.5rem;">
                                
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1rem; flex-wrap: wrap; gap: 1rem;">
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <span style="font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">AI Pick:</span>
                                        <span style="font-weight: 700; color: var(--text-primary); font-size: 1.1rem;">${bet.predictedOutcome}</span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <span style="font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Edge:</span>
                                        <span style="color: #10b981; font-weight: 700; background: rgba(16, 185, 129, 0.1); padding: 4px 10px; border-radius: 4px; border: 1px solid rgba(16, 185, 129, 0.2); font-size: 0.95rem;">+${mathProbString} Win Prob</span>
                                    </div>
                                </div>

                                <div style="font-size: 0.95rem; line-height: 1.6; color: var(--text-secondary); display: flex; gap: 12px; align-items: flex-start;">
                                    <span style="font-size: 1.4rem; line-height: 1;">🤖</span>
                                    <em style="font-style: italic;">"${bet.aiJustification}"</em>
                                </div>
                            </div>

                        </div>
                    `;
                }).join('');

            } catch (error) {
                console.error('Value Bets Error:', error);
                loadingState.style.display = 'none';
                errorState.style.display = 'block';
            }
        });
    </script>
    
    <style>
        .mp-spinner {
            width: 3.5rem;
            height: 3.5rem;
            border: 0.25em solid rgba(59, 130, 246, 0.2);
            border-right-color: #3b82f6;
            border-radius: 50%;
            animation: mp-spin 0.8s linear infinite;
        }
        
        @@keyframes mp-spin {
            to { transform: rotate(360deg); }
        }
    </style>
}
