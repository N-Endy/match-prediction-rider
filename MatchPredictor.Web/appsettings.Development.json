{
  "GroqApiKey": "(stored in user-secrets)",
  "GroqModel": "llama-3.3-70b-versatile",
  "ApiFootball": {
    "ApiKey": "(stored in user-secrets)",
    "BaseUrl": "https://v3.football.api-sports.io"
  },
  "SportyBet": {
    "BaseUrl": "https://www.sportybet.com",
    "SoccerSportId": "sr:sport:1",
    "Market1X2": "1"
  },
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "MatchPredictor": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/dev/logfile-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "ConnectionStrings": {
    "RedisConnection": "localhost:6379"
  },
  "ScrapingValues": {
    "ScrapingWebsite": "https://www.sports-ai.dev/predictions",
    "ScoresWebsite": "https://www.flashscore.mobi",
    "ScrapingMaxWaitTime": 60,
    "ScrapingMaxWaitInterval": 1000,
    "PredictionsButtonSelector": "//*[@id=\"__next\"]/div/div[2]/main/div[1]/div[2]/div[2]/div[2]/div[1]/div/button",
    "PredictionsFileName": "predictions.xlsx",
    "AiScoreWebsite": "https://m.aiscore.com"
  },
  "EPPlus": {
    "ExcelPackage": {
      "License": "NonCommercialPersonal:MatchPredictor"
    }
  }
}